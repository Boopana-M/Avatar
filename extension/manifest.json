{
  "manifest_version": 3,
  "name": "ISL Sign Language Avatar Overlay",
  "version": "1.0",
  "description": "Displays a bottom-right animated ISL avatar synced to YouTube playback.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "lib/three.min.js",
        "lib/GLTFLoader.js",
        "overlay.js",
        "content_script.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
